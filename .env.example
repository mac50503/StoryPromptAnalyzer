# Configuración de Jira
JIRA_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu-email@ejemplo.com
JIRA_API_TOKEN=tu_token_de_jira

# Campo custom para Acceptance Criteria (usa el botón Debug 🔍 para encontrar el tuyo)
# Puedes especificar múltiples campos separados por coma (se intentará en orden)
# Valores comunes: customfield_10000, customfield_10054, customfield_10007
JIRA_ACCEPTANCE_CRITERIA_FIELD=customfield_10054,customfield_10000

# Configuración de APIs de IA
OPENAI_API_KEY=tu_clave_de_openai
ANTHROPIC_API_KEY=tu_clave_de_anthropic
GROQ_API_KEY=tu_clave_de_groq

# Modelo a usar (openai/gpt-4-turbo, anthropic/claude-3-opus-20240229, groq/llama-3.1-70b-versatile, etc.)
AI_MODEL=gpt-4-turbo

# Idioma (es o en)
LANGUAGE=en
